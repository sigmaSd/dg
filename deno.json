{
  "name": "@sigmasd/dg",
  "version": "1.8.1",
  "license": "MIT",
  "exports": {
    ".": "./src/main.ts",
    "./interface": "./src/plugins/interface.ts",
    "./worker/client": "./src/plugins/worker/client.ts",
    "./worker/host": "./src/plugins/worker/host.ts"
  },
  "tasks": {
    "start": "deno run --allow-all --unstable-worker-options --no-prompt src/main.ts",
    "build": "deno run --allow-all build.ts"
  },
  "imports": {
    "@sigmasd/gtk": "jsr:@sigmasd/gtk@0.62.1",
    "@std/path": "jsr:@std/path@^1.1.4",
    "@std/fs": "jsr:@std/fs@1.0.23",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@opencode-ai/sdk": "npm:@opencode-ai/sdk@1.4.2",
    "fzf": "npm:fzf@^0.5.2"
  },

  "compilerOptions": {
    "lib": ["deno.ns", "deno.worker", "deno.unstable"]
  }
}
